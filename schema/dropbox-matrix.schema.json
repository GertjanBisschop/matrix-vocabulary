{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/peh/schemas/dropbox-matrix.schema.json",
  "title": "PEH matrix dropbox YAML",
  "description": "Simple JSON Schema for YAML files placed in the matrix-vocabulary dropbox folder.",
  "type": "object",
  "additionalProperties": false,
  "required": ["matrix_subclasses"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional editor hint pointing to this JSON Schema."
    },
    "matrix_subclasses": {
      "type": "array",
      "description": "Matrix classes to mint or update.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/matrixSubclass"
      }
    }
  },
  "$defs": {
    "matrixSubclass": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "parent_matrix"],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier",
          "description": "Local identifier, CURIE, or URI. Local identifiers are minted into matrix URIs by the pipeline."
        },
        "short_name": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Preferred human-readable label."
        },
        "ui_label": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "remark": {
          "type": "string",
          "minLength": 1
        },
        "parent_matrix": {
          "$ref": "#/$defs/identifier",
          "description": "Parent matrix class URI, CURIE, or local identifier."
        },
        "exact_matches": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/identifier"
          },
          "uniqueItems": true
        },
        "translations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/translation"
          }
        },
        "context_aliases": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contextAlias"
          }
        }
      }
    },
    "translation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["property_name", "language", "translated_value"],
      "properties": {
        "property_name": {
          "type": "string",
          "enum": ["name", "description", "ui_label", "remark"]
        },
        "language": {
          "type": "string",
          "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$",
          "description": "Language tag such as nl, fr, de, or en-GB."
        },
        "translated_value": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "contextAlias": {
      "type": "object",
      "additionalProperties": false,
      "required": ["property_name", "context", "alias"],
      "properties": {
        "property_name": {
          "type": "string",
          "enum": ["id", "short_name", "name", "description", "ui_label", "remark"]
        },
        "context": {
          "$ref": "#/$defs/identifier"
        },
        "alias": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "identifier": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(https?://[^\\s]+|[A-Za-z][A-Za-z0-9_.-]*:[^\\s]+|[A-Za-z][A-Za-z0-9_.-]*)$"
    }
  }
}
